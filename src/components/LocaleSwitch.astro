---
import {
  LOCALES,
  LOCALE_LABELS,
  switchLocalePath,
  type Locale,
} from '../i18n/config'

interface Props {
  locale: Locale
  label: string
}
const { locale, label } = Astro.props
const pathname = Astro.url.pathname
---

<nav
  aria-label={label}
  class="flex items-center rounded-lg border border-border p-0.5 text-xs font-semibold"
>
  {
    LOCALES.map((l) => (
      <a
        href={switchLocalePath(pathname, l)}
        aria-label={LOCALE_LABELS[l]}
        aria-current={l === locale ? 'true' : undefined}
        class={
          l === locale
            ? 'rounded-md bg-surface-2 px-2 py-1 text-fg'
            : 'rounded-md px-2 py-1 text-muted transition-colors hover:text-fg'
        }
      >
        {l.toUpperCase()}
      </a>
    ))
  }
</nav>
