---
import KutupLogo from './KutupLogo.astro'
import ThemeToggle from './ThemeToggle.astro'
import LocaleSwitch from './LocaleSwitch.astro'
import MobileNav from './islands/MobileNav.tsx'
import { LINKS } from '../consts'
import { localePath, type Locale } from '../i18n/config'
import { getDict } from '../i18n'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
const t = getDict(locale)

const items = [
  { label: t.nav.features, href: localePath(locale, '/features'), external: false },
  { label: t.nav.download, href: localePath(locale, '/download'), external: false },
  { label: t.nav.selfHost, href: localePath(locale, '/self-host'), external: false },
  { label: t.nav.instances, href: localePath(locale, '/instances'), external: false },
  { label: t.nav.docs, href: LINKS.docs, external: true },
]
---

<header
  class="sticky top-0 z-50 border-b border-border/70 bg-ink/80 backdrop-blur supports-[backdrop-filter]:bg-ink/60"
>
  <div class="relative mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href={localePath(locale, '/')} class="flex items-center gap-2.5" aria-label="Kutup home">
      <KutupLogo size={30} />
      <span class="text-lg font-semibold tracking-tight text-fg">Kutup</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {
        items.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="rounded-lg px-3 py-2 text-sm text-muted transition-colors hover:text-fg"
          >
            {item.label}
            {item.external ? ' ↗' : ''}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <LocaleSwitch locale={locale} label={t.header.switchLanguage} />
      <ThemeToggle label={t.header.switchTheme} />
      <a
        href={LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-sm text-muted transition-colors hover:text-fg md:block"
      >
        GitHub ↗
      </a>
      <a
        href={localePath(locale, '/download')}
        class="hidden items-center justify-center rounded-lg bg-ice px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-pale md:inline-flex"
      >
        {t.header.getKutup}
      </a>
      <MobileNav client:load items={items} githubUrl={LINKS.github} />
    </div>
  </div>
</header>
