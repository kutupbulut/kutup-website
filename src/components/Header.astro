---
import KutupLogo from './KutupLogo.astro'
import MobileNav from './islands/MobileNav.tsx'
import { NAV, LINKS } from '../consts'

const items = NAV.map((n) => ({
  label: n.label,
  href: n.href,
  external: 'external' in n ? n.external : false,
}))
---

<header
  class="sticky top-0 z-50 border-b border-border/70 bg-ink/80 backdrop-blur supports-[backdrop-filter]:bg-ink/60"
>
  <div class="relative mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2.5" aria-label="Kutup home">
      <KutupLogo size={30} />
      <span class="text-lg font-semibold tracking-tight text-fg">Kutup</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {
        items.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="rounded-lg px-3 py-2 text-sm text-muted transition-colors hover:text-fg"
          >
            {item.label}
            {item.external ? ' ↗' : ''}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href={LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted transition-colors hover:text-fg"
      >
        GitHub ↗
      </a>
      <a
        href="/download"
        class="inline-flex items-center justify-center rounded-lg bg-ice px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-pale"
      >
        Get Kutup
      </a>
    </div>

    <MobileNav client:load items={items} githubUrl={LINKS.github} />
  </div>
</header>
