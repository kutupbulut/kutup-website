---
import KutupLogo from './KutupLogo.astro'
import { LINKS } from '../consts'
import { fill, localePath, type Locale } from '../i18n/config'
import { getDict } from '../i18n'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
const t = getDict(locale)

const year = new Date().getFullYear()

const columns = [
  {
    title: t.footer.product,
    links: [
      { label: t.nav.features, href: localePath(locale, '/features') },
      { label: t.nav.download, href: localePath(locale, '/download') },
      { label: t.nav.selfHost, href: localePath(locale, '/self-host') },
      { label: t.nav.instances, href: localePath(locale, '/instances') },
    ],
  },
  {
    title: t.footer.resources,
    links: [
      { label: t.footer.documentation, href: LINKS.docs, external: true },
      { label: 'GitHub', href: LINKS.github, external: true },
      { label: t.footer.releases, href: LINKS.releases, external: true },
      { label: t.footer.issues, href: LINKS.issues, external: true },
    ],
  },
]

const licenseHtml = fill(t.footer.license, { year, license: LINKS.license })
const brandHtml = fill(t.footer.brand, { email: LINKS.email })
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <a href={localePath(locale, '/')} class="flex items-center gap-2.5" aria-label="Kutup home">
        <KutupLogo size={28} />
        <span class="text-lg font-semibold tracking-tight text-fg">Kutup</span>
      </a>
      <p class="mt-3 max-w-sm text-sm text-muted">{t.footer.blurb}</p>
    </div>

    {
      columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-fg">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={'external' in link && link.external ? '_blank' : undefined}
                  rel={'external' in link && link.external ? 'noopener noreferrer' : undefined}
                  class="text-sm text-muted transition-colors hover:text-fg"
                >
                  {link.label}
                  {'external' in link && link.external ? ' ↗' : ''}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="border-t border-border">
    <div
      class="rich mx-auto flex max-w-6xl flex-col gap-3 px-6 py-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p set:html={licenseHtml} />
      <p set:html={brandHtml} />
    </div>
  </div>
</footer>
