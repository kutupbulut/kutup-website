---
import Base from '../layouts/Base.astro'
import Section from '../components/Section.astro'
import CodeBlock from '../components/CodeBlock.astro'
import OsDownload from '../components/islands/OsDownload.tsx'
import { LINKS } from '../consts'
---

<Base
  title="Download"
  description="Get Kutup for desktop (macOS, Windows, Linux), mobile (iOS, Android), or the command line. All clients are end-to-end encrypted."
>
  <section class="bg-glacier border-b border-border">
    <div class="mx-auto max-w-3xl px-6 py-16 text-center sm:py-20">
      <p class="text-sm font-semibold uppercase tracking-widest text-ice">Download</p>
      <h1 class="mt-3 text-balance text-4xl font-bold tracking-tight text-fg sm:text-5xl">
        Get Kutup on every device
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-lg text-muted">
        Web, desktop, mobile, and a full CLI — every client encrypts end-to-end
        before anything touches the network. You’ll point each one at your own
        Kutup server.
      </p>
      <p class="mt-4 inline-flex items-center gap-2 rounded-full border border-amber/40 bg-amber/10 px-3 py-1 text-xs font-medium text-amber">
        Pre-release — binaries are published on GitHub Releases
      </p>
    </div>
  </section>

  <Section class="!pt-12">
    <div class="mx-auto max-w-3xl">
      <OsDownload client:load releasesUrl={LINKS.releases} />
    </div>
  </Section>

  <Section class="!pt-0">
    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Mobile -->
      <div class="rounded-2xl border border-border bg-surface p-6 sm:p-8">
        <p class="text-sm font-semibold uppercase tracking-widest text-ice">Mobile</p>
        <h3 class="mt-2 text-2xl font-bold text-fg">iOS &amp; Android</h3>
        <p class="mt-2 text-sm text-muted">
          Native mobile builds via Tauri. iOS persists your session in the
          keychain. Distribution is in progress — track availability on GitHub
          Releases.
        </p>
        <a
          href={LINKS.releases}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex items-center justify-center rounded-lg border border-border bg-surface-2 px-5 py-2.5 text-sm font-medium text-fg transition-colors hover:border-ice/60 hover:text-ice"
        >
          Check Releases ↗
        </a>
      </div>

      <!-- Web -->
      <div class="rounded-2xl border border-border bg-surface p-6 sm:p-8">
        <p class="text-sm font-semibold uppercase tracking-widest text-ice">Web</p>
        <h3 class="mt-2 text-2xl font-bold text-fg">Use it in the browser</h3>
        <p class="mt-2 text-sm text-muted">
          The full web app — including office-document editing — ships with every
          self-hosted instance. Stand up your own server and open it in any
          modern browser.
        </p>
        <a
          href="/self-host"
          class="mt-5 inline-flex items-center justify-center rounded-lg border border-border bg-surface-2 px-5 py-2.5 text-sm font-medium text-fg transition-colors hover:border-ice/60 hover:text-ice"
        >
          Self-hosting guide
        </a>
      </div>
    </div>
  </Section>

  <!-- CLI -->
  <section class="border-t border-border bg-surface">
    <Section
      eyebrow="Command line"
      title="Install the CLI"
      subtitle="End-to-end encrypted file operations from your shell — including multi-GB uploads the browser can’t handle."
    >
      <div class="mx-auto mt-10 max-w-3xl space-y-6">
        <div>
          <h3 class="mb-3 text-lg font-semibold text-fg">With Go (≥ 1.22)</h3>
          <CodeBlock lang="sh" code="go install github.com/kutupbulut/kutup/cmd/kutup@latest" />
          <p class="mt-2 text-sm text-muted">Ensure <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-xs text-ice">$GOPATH/bin</code> is on your <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-xs text-ice">$PATH</code>.</p>
        </div>
        <div>
          <h3 class="mb-3 text-lg font-semibold text-fg">From source</h3>
          <CodeBlock
            lang="sh"
            code={`git clone https://github.com/kutupbulut/kutup.git
cd kutup/cmd/kutup
go build -o ~/.local/bin/kutup .`}
          />
        </div>
        <p class="text-sm text-muted">
          Prefer a binary? Tagged builds for Linux / macOS / Windows (amd64 +
          arm64) are on
          <a href={LINKS.releases} target="_blank" rel="noopener noreferrer" class="text-ice hover:text-pale"> GitHub Releases ↗</a>.
        </p>
      </div>
    </Section>
  </section>
</Base>
