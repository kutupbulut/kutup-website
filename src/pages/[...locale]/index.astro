---
import Base from '../../layouts/Base.astro'
import Section from '../../components/Section.astro'
import Button from '../../components/Button.astro'
import Screenshot from '../../components/Screenshot.astro'
import FeatureCard from '../../components/FeatureCard.astro'
import { LINKS } from '../../consts'
import {
  fill,
  getStaticLocalePaths,
  localeFromParam,
  localePath,
} from '../../i18n/config'
import { getDict } from '../../i18n'

export function getStaticPaths() {
  return getStaticLocalePaths()
}

const locale = localeFromParam(Astro.params.locale)
const t = getDict(locale)

const pillarIcons = ['🔒', '⚡', '🛰️']

// Screenshots zip with the translated highlight copy by index.
const highlightImgs = [
  '/screenshots/01-drive.png',
  '/screenshots/02-notes-editor.png',
  '/screenshots/03-xlsx.png',
  '/screenshots/04-whiteboard.png',
  '/screenshots/05-version-history.png',
  '/screenshots/06-settings.png',
]

const stack = [
  'Go 1.25 · Fiber',
  'PostgreSQL 16',
  'React 18 · Vite',
  'libsodium · XChaCha20-Poly1305',
  'Yjs CRDT',
  'OnlyOffice',
  'Excalidraw',
  'SeaweedFS',
  'Docker Compose',
]

const acknowledgements = [
  { name: 'OnlyOffice', href: 'https://github.com/ONLYOFFICE' },
  { name: 'CryptPad', href: 'https://github.com/cryptpad/cryptpad' },
  { name: 'Ente', href: 'https://github.com/ente-io/ente' },
  { name: 'Excalidraw', href: 'https://github.com/excalidraw/excalidraw' },
]
---

<Base locale={locale}>
  <!-- Hero -->
  <section class="bg-glacier relative overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 sm:pt-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-3 py-1 text-xs font-medium text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-ice"></span>
          {t.home.hero.badge}
        </p>
        <h1
          class="mt-6 text-balance text-4xl font-bold tracking-tight text-fg sm:text-6xl"
          set:html={t.home.hero.title}
        />
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted sm:text-xl">
          {t.home.hero.sub}
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <Button href={localePath(locale, '/self-host')} size="lg">{t.home.hero.ctaSelfHost}</Button>
          <Button href={localePath(locale, '/download')} size="lg" variant="secondary">{t.home.hero.ctaDownload}</Button>
          <Button href={LINKS.github} size="lg" variant="ghost" external>{t.home.hero.ctaStar}</Button>
        </div>
      </div>

      <div class="mx-auto mt-14 max-w-5xl">
        <Screenshot
          src="/screenshots/01-drive.png"
          alt={t.home.hero.screenshotAlt}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <Section class="!py-14">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        t.home.pillars.map((pillar, i) => (
          <FeatureCard title={pillar.title} icon={pillarIcons[i]}>
            {pillar.body}
          </FeatureCard>
        ))
      }
    </div>
  </Section>

  <!-- Highlights, alternating -->
  <Section
    eyebrow={t.home.highlights.eyebrow}
    title={t.home.highlights.title}
    subtitle={t.home.highlights.subtitle}
  >
    <div class="mt-14 space-y-20">
      {
        t.home.highlights.items.map((h, i) => (
          <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <h3 class="text-2xl font-bold text-fg">{h.title}</h3>
              <p class="mt-3 text-pretty leading-relaxed text-muted">{h.body}</p>
            </div>
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <Screenshot src={highlightImgs[i]} alt={h.alt} />
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-14 text-center">
      <Button href={localePath(locale, '/features')} variant="secondary">{t.home.highlights.cta}</Button>
    </div>
  </Section>

  <!-- Architecture -->
  <section class="border-y border-border bg-surface">
    <Section
      eyebrow={t.home.architecture.eyebrow}
      title={t.home.architecture.title}
      subtitle={t.home.architecture.subtitle}
    >
      <div class="mt-12 grid items-stretch gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-border bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-ice">{t.home.architecture.browserA.title}</p>
          <p class="mt-3 text-sm text-muted">{t.home.architecture.browserA.body}</p>
        </div>
        <div class="rounded-2xl border border-ice/40 bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-pale">{t.home.architecture.relay.title}</p>
          <p class="mt-1 text-xs font-medium text-muted">{t.home.architecture.relay.tag}</p>
          <p class="mt-3 text-sm text-muted">{t.home.architecture.relay.body}</p>
        </div>
        <div class="rounded-2xl border border-border bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-ice">{t.home.architecture.browserB.title}</p>
          <p class="mt-3 text-sm text-muted">{t.home.architecture.browserB.body}</p>
        </div>
      </div>
      <p
        class="rich mt-8 text-center text-sm text-muted"
        set:html={fill(t.home.architecture.docsNote, { docs: LINKS.docs })}
      />
    </Section>
  </section>

  <!-- Tech stack -->
  <Section eyebrow={t.home.stack.eyebrow} title={t.home.stack.title}>
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      {
        stack.map((s) => (
          <span class="rounded-full border border-border bg-surface px-4 py-2 text-sm text-muted">
            {s}
          </span>
        ))
      }
    </div>
  </Section>

  <!-- Acknowledgements -->
  <Section eyebrow={t.home.ack.eyebrow} title={t.home.ack.title} class="!pt-0">
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        acknowledgements.map((a, i) => (
          <a
            href={a.href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl border border-border bg-surface p-5 transition-colors hover:border-ice/50"
          >
            <p class="font-semibold text-fg">{a.name} ↗</p>
            <p class="mt-1 text-sm text-muted">{t.home.ack.notes[i]}</p>
          </a>
        ))
      }
    </div>
  </Section>

  <!-- Final CTA -->
  <section class="bg-glacier border-t border-border">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl">
        {t.home.cta.title}
      </h2>
      <p
        class="rich mx-auto mt-4 max-w-xl text-pretty text-lg text-muted"
        set:html={t.home.cta.body}
      />
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <Button href={localePath(locale, '/self-host')} size="lg">{t.home.cta.getStarted}</Button>
        <Button href={LINKS.github} size="lg" variant="secondary" external>{t.home.cta.viewSource}</Button>
      </div>
    </div>
  </section>
</Base>
