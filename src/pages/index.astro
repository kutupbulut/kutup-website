---
import Base from '../layouts/Base.astro'
import Section from '../components/Section.astro'
import Button from '../components/Button.astro'
import Screenshot from '../components/Screenshot.astro'
import FeatureCard from '../components/FeatureCard.astro'
import { LINKS } from '../consts'

const highlights = [
  {
    title: 'Files the server can’t read',
    img: '/screenshots/01-drive.png',
    alt: 'Kutup Drive — file browser with folders, uploads, and storage quota',
    body:
      'Nested collections, drag-and-drop upload, public share links, and per-user folder shares with read/upload/delete permissions. Filenames, MIME types, and folder structure are encrypted client-side. Stream upload keeps multi-GB files out of memory. Storage backs onto SeaweedFS (S3-compatible).',
  },
  {
    title: 'Live notes & code',
    img: '/screenshots/02-notes-editor.png',
    alt: 'Notes editor — CodeMirror with version-history sidebar',
    body:
      'CodeMirror 6 + Yjs CRDT for Markdown, plain text, and 20+ code languages. Multi-user cursors and selection presence with a per-user awareness color. Every edit is a Yjs update wrapped in an AEAD envelope — the server gets opaque ciphertext.',
  },
  {
    title: 'Office docs, fully client-side',
    img: '/screenshots/03-xlsx.png',
    alt: 'Spreadsheet editor with conditional formatting',
    body:
      '.docx, .xlsx, and .pptx via OnlyOffice running entirely in the browser using the CryptPad pattern. Document state is never decrypted server-side. Live cell-selection presence, per-user colors, formulas, charts, and conditional formatting.',
  },
  {
    title: 'Whiteboards',
    img: '/screenshots/04-whiteboard.png',
    alt: 'Excalidraw whiteboard',
    body:
      '.excalidraw files open in Excalidraw with cross-tab sync and last-write-wins reconciliation — wrapped in the same end-to-end-encrypted envelope as everything else.',
  },
  {
    title: 'Version history on every file',
    img: '/screenshots/05-version-history.png',
    alt: 'Version history sidebar',
    body:
      'Every save creates a versioned snapshot. Open the History sidebar in any editor, scroll back, and restore. Named saves are kept forever; anonymous saves age out. Notes, office, and whiteboards all share the same plumbing.',
  },
  {
    title: 'You own your keys',
    img: '/screenshots/06-settings.png',
    alt: 'Settings — devices and presence color',
    body:
      'Multi-device with per-device Ed25519 keypairs you can revoke individually. A 24-word BIP39 recovery phrase doubles as the second factor for account recovery. Optional TOTP 2FA. Your picked presence color follows you across editors.',
  },
]

const stack = [
  'Go 1.25 · Fiber',
  'PostgreSQL 16',
  'React 18 · Vite',
  'libsodium · XChaCha20-Poly1305',
  'Yjs CRDT',
  'OnlyOffice',
  'Excalidraw',
  'SeaweedFS',
  'Docker Compose',
]

const acknowledgements = [
  { name: 'OnlyOffice', href: 'https://github.com/ONLYOFFICE', note: 'powers collaborative office editing' },
  { name: 'CryptPad', href: 'https://github.com/cryptpad/cryptpad', note: 'the client-only encrypted-office pattern' },
  { name: 'Ente', href: 'https://github.com/ente-io/ente', note: 'the E2EE key-hierarchy model' },
  { name: 'Excalidraw', href: 'https://github.com/excalidraw/excalidraw', note: 'the embedded whiteboard + reconciliation' },
]
---

<Base>
  <!-- Hero -->
  <section class="bg-glacier relative overflow-hidden">
    <div class="bg-grid absolute inset-0 opacity-60"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-20 sm:pt-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-3 py-1 text-xs font-medium text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-ice"></span>
          End-to-end encrypted · self-hosted · real-time collab
        </p>
        <h1 class="mt-6 text-balance text-4xl font-bold tracking-tight text-fg sm:text-6xl">
          The self-hosted Drive your server
          <span class="text-ice"> can’t read</span>.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted sm:text-xl">
          Kutup is an end-to-end encrypted Google Drive you run yourself — with
          real-time collaboration for notes, office docs, and whiteboards. Every
          file, filename, edit, and cursor is encrypted in your browser before
          it leaves the page.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <Button href="/self-host" size="lg">Self-host Kutup</Button>
          <Button href="/download" size="lg" variant="secondary">Download apps</Button>
          <Button href={LINKS.github} size="lg" variant="ghost" external>Star on GitHub ↗</Button>
        </div>
      </div>

      <div class="mx-auto mt-14 max-w-5xl">
        <Screenshot
          src="/screenshots/01-drive.png"
          alt="Kutup Drive interface"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <Section class="!py-14">
    <div class="grid gap-6 sm:grid-cols-3">
      <FeatureCard title="Zero-knowledge server" icon="🔒">
        Keys are derived in your browser from your password and recovery phrase.
        The server stores only AEAD-encrypted bytes — it can route and persist
        them, but never read them.
      </FeatureCard>
      <FeatureCard title="Collaboration, still encrypted" icon="⚡">
        The differentiator: real-time editing without giving up E2EE. The relay
        sees a stream of opaque, Ed25519-signed frames — not a single byte of
        content.
      </FeatureCard>
      <FeatureCard title="Yours to run & federate" icon="🛰️">
        Self-hosted by design via Docker Compose. Federation lets you share a
        folder with someone on a different Kutup server without either backend
        ever seeing plaintext.
      </FeatureCard>
    </div>
  </Section>

  <!-- Highlights, alternating -->
  <Section
    eyebrow="What’s inside"
    title="One encrypted workspace for everything"
    subtitle="Files, notes, code, spreadsheets, slides, and whiteboards — all under the same hard-baked encryption boundary."
  >
    <div class="mt-14 space-y-20">
      {
        highlights.map((h, i) => (
          <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-14">
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <h3 class="text-2xl font-bold text-fg">{h.title}</h3>
              <p class="mt-3 text-pretty leading-relaxed text-muted">{h.body}</p>
            </div>
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <Screenshot src={h.img} alt={h.alt} />
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-14 text-center">
      <Button href="/features" variant="secondary">Explore all features</Button>
    </div>
  </Section>

  <!-- Architecture -->
  <section class="border-y border-border bg-surface">
    <Section
      eyebrow="Architecture in 30 seconds"
      title="The relay routes ciphertext it can never decrypt"
      subtitle="Every collab frame is encrypted in the browser, signed with a per-device Ed25519 key, and sent through an opaque WebSocket relay."
    >
      <div class="mt-12 grid items-stretch gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-border bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-ice">Browser A</p>
          <p class="mt-3 text-sm text-muted">AEAD-encrypt + sign the update with a per-device Ed25519 key.</p>
        </div>
        <div class="rounded-2xl border border-ice/40 bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-pale">Go relay</p>
          <p class="mt-1 text-xs font-medium text-muted">ciphertext only</p>
          <p class="mt-3 text-sm text-muted">Verify the signature, route by file, persist and broadcast — bytes unchanged.</p>
        </div>
        <div class="rounded-2xl border border-border bg-ink p-6 text-center">
          <p class="text-sm font-semibold uppercase tracking-widest text-ice">Browser B</p>
          <p class="mt-3 text-sm text-muted">Verify, decrypt, and apply. Per-file keys derive from the collection master key.</p>
        </div>
      </div>
      <p class="mt-8 text-center text-sm text-muted">
        Full key hierarchy, login flow, federation model, and wire spec live in the
        <a href={LINKS.docs} target="_blank" rel="noopener noreferrer" class="text-ice hover:text-pale"> documentation ↗</a>.
      </p>
    </Section>
  </section>

  <!-- Tech stack -->
  <Section eyebrow="Built on" title="A pragmatic, auditable stack">
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      {
        stack.map((s) => (
          <span class="rounded-full border border-border bg-surface px-4 py-2 text-sm text-muted">
            {s}
          </span>
        ))
      }
    </div>
  </Section>

  <!-- Acknowledgements -->
  <Section
    eyebrow="Standing on shoulders"
    title="Built with great open-source projects"
    class="!pt-0"
  >
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        acknowledgements.map((a) => (
          <a
            href={a.href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl border border-border bg-surface p-5 transition-colors hover:border-ice/50"
          >
            <p class="font-semibold text-fg">{a.name} ↗</p>
            <p class="mt-1 text-sm text-muted">{a.note}</p>
          </a>
        ))
      }
    </div>
  </Section>

  <!-- Final CTA -->
  <section class="bg-glacier border-t border-border">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl">
        Run your own encrypted Drive today
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-pretty text-lg text-muted">
        Clone the repo, fill in a few secrets, and <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-sm text-ice">docker compose up</code>. You’re the only one who can read your data.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <Button href="/self-host" size="lg">Get started</Button>
        <Button href={LINKS.github} size="lg" variant="secondary" external>View source ↗</Button>
      </div>
    </div>
  </section>
</Base>
