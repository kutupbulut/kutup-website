---
import Base from '../layouts/Base.astro'
import Button from '../components/Button.astro'
import KutupLogo from '../components/KutupLogo.astro'
import { getDict } from '../i18n'

// Cloudflare serves a single dist/404.html for every missed path, so this
// page renders the default locale and the inline script below swaps to
// Turkish when the URL is under /tr/.
const t = getDict('en')
const tr = getDict('tr')
---

<Base title={t.notFound.metaTitle} description={t.notFound.metaDescription}>
  <section class="bg-glacier">
    <div class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-6 py-24 text-center">
      <KutupLogo size={48} />
      <p class="mt-8 text-sm font-semibold uppercase tracking-widest text-ice">404</p>
      <h1 id="nf-title" class="mt-3 text-balance text-4xl font-bold tracking-tight text-fg sm:text-5xl">
        {t.notFound.title}
      </h1>
      <p id="nf-body" class="mt-4 max-w-md text-pretty text-muted">
        {t.notFound.body}
      </p>
      <div id="nf-actions" class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/" size="lg">{t.notFound.home}</Button>
        <Button href="/features" size="lg" variant="secondary">{t.notFound.features}</Button>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ tr: tr.notFound }}>
    if (location.pathname === '/tr' || location.pathname.startsWith('/tr/')) {
      document.documentElement.lang = 'tr'
      document.title = `${tr.metaTitle} — Kutup`
      document.getElementById('nf-title').textContent = tr.title
      document.getElementById('nf-body').textContent = tr.body
      const [home, features] = document.querySelectorAll('#nf-actions a')
      home.textContent = tr.home
      home.href = '/tr/'
      features.textContent = tr.features
      features.href = '/tr/features'
    }
  </script>
</Base>
